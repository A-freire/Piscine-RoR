<% if @saved %>
document.getElementById("book-form-container").innerHTML = "";
document.getElementById("book-count").innerHTML = "<%= j render('count', books: @books) %>";
document.getElementById("books-table-body").innerHTML = "<%= j render(@books) %>";
<% else %>
document.getElementById("book-form-container").innerHTML = "<%= j render('form', book: @book) %>";
<% end %>
