<section class="hero-card">
  <p class="panel-kicker">Realtime chat with Action Cable</p>
  <h2>Authenticate and watch messages appear instantly for every connected client.</h2>
  <p class="hero-copy">
    This first chat version keeps things intentionally simple: one shared room, authenticated users, and realtime delivery through Action Cable.
  </p>

  <div class="hero-actions">
    <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
    <%= link_to "Create account", new_user_registration_path, class: "nav-link primary-link" %>
  </div>
</section>
