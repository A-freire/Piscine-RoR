<%= form_with model: chat_room, local: true do |form| %>
  <% if chat_room.errors.any? %>
    <div class="error-box">
      <% chat_room.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <div class="stacked-field">
    <%= form.label :title, "Room name" %>
    <%= form.text_field :title, autocomplete: "off", placeholder: "backend-support" %>
  </div>

  <%= form.submit "Create room", class: "nav-link primary-link submit-link" %>
<% end %>
