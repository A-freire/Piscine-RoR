<section class="hero-card">
  <p class="panel-kicker">Realtime chat with Action Cable</p>
  <h2>Authenticate, create rooms, and watch messages appear instantly across clients.</h2>
  <p class="hero-copy">
    This version is set up for Docker instead of a VM, keeps broadcasting work in a buffered job queue,
    and exposes live notifications for every message written by someone else.
  </p>

  <div class="hero-actions">
    <%= link_to "Sign in", new_user_session_path, class: "nav-link" %>
    <%= link_to "Create account", new_user_registration_path, class: "nav-link primary-link" %>
  </div>
</section>
