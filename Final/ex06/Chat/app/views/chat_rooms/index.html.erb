<section class="rooms-page">
  <div class="room-creation-card">
    <p class="panel-kicker">Exercise 05 + 06</p>
    <h2>Create a new chat room</h2>
    <p>Each room belongs to its creator. Deleting the creator removes the room and every message inside it.</p>

    <%= render "room_form", chat_room: @new_chat_room %>
  </div>

  <div class="room-list-card">
    <div class="section-heading">
      <h2>Available rooms</h2>
      <p>Select a room to open its live conversation.</p>
    </div>

    <div data-room-list-container>
      <%= render "room_list", chat_rooms: @chat_rooms %>
    </div>
  </div>
</section>
