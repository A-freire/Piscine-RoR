<%= form_with model: product, class: "form-grid" do |form| %>
  <% if product.errors.any? %>
    <div class="flash flash--alert"><%= product.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Nom" %>
    <%= form.text_field :name %>
  </div>

  <div class="field">
    <%= form.label :description, "Description" %>
    <%= form.text_area :description %>
  </div>

  <div class="field">
    <%= form.label :price, "Prix" %>
    <%= form.number_field :price, step: "0.01", min: "0" %>
  </div>

  <div class="field">
    <%= form.label :brand_id, "Marque" %>
    <%= form.collection_select :brand_id, Brand.order(:name), :id, :name %>
  </div>

  <div class="field">
    <%= form.label :pict, "Image" %>
    <%= form.file_field :pict %>
  </div>

  <div class="hero-actions">
    <%= form.submit product.persisted? ? "Mettre a jour" : "Creer le produit" %>
    <%= link_to "Annuler", products_path, class: "ghost-link" %>
  </div>
<% end %>
