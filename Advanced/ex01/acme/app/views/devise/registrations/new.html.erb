<section class="form-card">
  <p class="eyebrow">Compte</p>
  <h1 class="section-title">Creer un compte</h1>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "form-grid" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <%= f.label :name, "Nom" %>
      <%= f.text_field :name, autofocus: true, autocomplete: "name" %>
    </div>

    <div class="field">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, autocomplete: "email" %>
    </div>

    <div class="field">
      <%= f.label :bio, "Biographie" %>
      <%= f.text_area :bio %>
    </div>

    <div class="field">
      <%= f.label :password, "Mot de passe" %>
      <%= f.password_field :password, autocomplete: "new-password" %>
      <% if @minimum_password_length %>
        <span class="muted"><%= @minimum_password_length %> caracteres minimum</span>
      <% end %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation, "Confirmation" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password" %>
    </div>

    <div class="hero-actions">
      <%= f.submit "Creer mon compte" %>
      <%= render "devise/shared/links" %>
    </div>
  <% end %>
</section>
