<article class="product-card">
  <div class="product-card__image">
    <% if (image_url = transformed_image_url(product.pict, width: 640, height: 480)).present? %>
      <%= image_tag image_url, alt: product.name %>
    <% else %>
      <div class="image-fallback">Acme</div>
    <% end %>
  </div>

  <div class="product-card__body">
    <p class="eyebrow"><%= product.brand.name %></p>
    <h2 class="product-card__title"><%= link_to product.name, product_path(product) %></h2>
    <p class="product-card__meta"><%= truncate(product.description, length: 110) %></p>
    <span class="price-tag"><%= money(product.price) %></span>

    <div class="stack-actions">
      <%= button_to "Ajouter au panier", cart_items_path(product_id: product.id) %>

      <% if can_manage_catalog? %>
        <div class="inline-actions">
          <%= link_to "Editer", edit_product_path(product), class: "ghost-link" %>
          <%= button_to "Supprimer", product_path(product), method: :delete, class: "button--light" %>
        </div>
      <% end %>
    </div>
  </div>
</article>
