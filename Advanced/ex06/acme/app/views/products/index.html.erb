<section class="hero-card">
  <p class="eyebrow">Catalogue</p>
  <h1 class="headline">Une vitrine e-commerce simple, complete et prete a vendre.</h1>
  <p class="subhead">
    Retrouvez les produits, les marques, l'authentification, le panier persistant et le back-office sur une seule application Rails.
  </p>
</section>

<section class="page-head">
  <div>
    <p class="eyebrow">Produits</p>
    <h2 class="section-title"><%= @total_products %> references disponibles</h2>
    <p class="muted">Page <%= @page %> sur <%= @total_pages %>, avec <%= @products.size %> produits affiches.</p>
  </div>

  <% if can_manage_catalog? %>
    <div class="hero-actions">
      <%= link_to "Nouveau produit", new_product_path, class: "button button--dark" %>
      <%= link_to "Nouvelle marque", new_brand_path, class: "ghost-link" %>
    </div>
  <% end %>
</section>

<% if @total_pages > 1 %>
  <nav class="pagination" aria-label="Pagination du catalogue">
    <% if @page > 1 %>
      <%= link_to "Page precedente", products_path(page: @page - 1), class: "ghost-link" %>
    <% end %>

    <span class="meta-pill">Page <%= @page %> / <%= @total_pages %></span>

    <% if @page < @total_pages %>
      <%= link_to "Page suivante", products_path(page: @page + 1), class: "button button--dark" %>
    <% end %>
  </nav>
<% end %>

<div class="catalog-layout">
  <section class="product-grid">
    <% @products.each do |product| %>
      <%= render "product_card", product: product %>
    <% end %>
  </section>

  <aside>
    <%= render "shared/cart", cart: @cart %>

    <div class="panel">
      <p class="eyebrow">Navigation</p>
      <h2 class="section-title">Autres espaces</h2>
      <div class="stack-actions">
        <%= link_to "Voir les marques", brands_path, class: "ghost-link" %>
        <% if current_user&.backoffice_access? %>
          <%= link_to "Ouvrir le panel admin", rails_admin_path, class: "button button--dark" %>
        <% end %>
      </div>
    </div>
  </aside>
</div>
