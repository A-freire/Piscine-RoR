<section class="page-head">
  <div>
    <p class="eyebrow">Marques</p>
    <h1 class="section-title">Toutes les marques du catalogue</h1>
  </div>

  <% if can_manage_catalog? %>
    <%= link_to "Nouvelle marque", new_brand_path, class: "button button--dark" %>
  <% end %>
</section>

<section class="brand-grid">
  <% @brands.each do |brand| %>
    <article class="brand-card">
      <div class="brand-card__image">
        <% if (image_url = transformed_image_url(brand.avatar, width: 640, height: 480)).present? %>
          <%= image_tag image_url, alt: brand.name %>
        <% else %>
          <div class="image-fallback">Marque</div>
        <% end %>
      </div>

      <div class="brand-card__body">
        <p class="eyebrow">Catalogue</p>
        <h2 class="brand-card__title"><%= link_to brand.name, brand_path(brand) %></h2>
        <p class="brand-card__meta"><%= pluralize(brand.products.count, "produit") %></p>

        <% if can_manage_catalog? %>
          <div class="inline-actions">
            <%= link_to "Editer", edit_brand_path(brand), class: "ghost-link" %>
            <%= button_to "Supprimer", brand_path(brand), method: :delete, class: "button--light" %>
          </div>
        <% end %>
      </div>
    </article>
  <% end %>
</section>
