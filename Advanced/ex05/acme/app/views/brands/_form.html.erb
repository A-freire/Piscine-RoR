<%= form_with model: brand, class: "form-grid" do |form| %>
  <% if brand.errors.any? %>
    <div class="flash flash--alert"><%= brand.errors.full_messages.to_sentence %></div>
  <% end %>

  <div class="field">
    <%= form.label :name, "Nom" %>
    <%= form.text_field :name %>
  </div>

  <div class="field">
    <%= form.label :avatar, "Image" %>
    <%= form.file_field :avatar %>
  </div>

  <div class="hero-actions">
    <%= form.submit brand.persisted? ? "Mettre a jour" : "Creer la marque" %>
    <%= link_to "Annuler", brands_path, class: "ghost-link" %>
  </div>
<% end %>
